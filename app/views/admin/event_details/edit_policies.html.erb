<% title "Policy uploads for #{@event_detail.group.name}" %>

<h1><%= yield(:title) %></h1>

<%= simple_form_for(@event_detail, url: update_policies_admin_event_detail_path(@event_detail), html: { method: :patch }) do |f| %> 
	<%= f.error_notification %>
	
	<%= f.hidden_field :id %>

    <p>Child Safe Policy:</p>
	<% if @event_detail.child_safe_policy.attached? %>
		<% if @event_detail.child_safe_policy.representable? %>
		    <%= link_to(image_tag(@event_detail.child_safe_policy.representation(resize_to_limit: [80, 100])), rails_blob_path(@event_detail.child_safe_policy, disposition: "attachment")) %>
		<% else %>
		    <%= link_to "File", rails_blob_path(@event_detail.child_safe_policy, disposition: "attachment") %>
		<% end %>
    	<%= f.input :policy_child_safe_checked, label: "Checked?" %>
		<br/>
		<br/>
	<% end %>
	
    <p>Code of Conduct:</p>
	<% if @event_detail.code_of_conduct.attached? %>
		<% if @event_detail.code_of_conduct.representable? %>
		    <%= link_to(image_tag(@event_detail.code_of_conduct.representation(resize_to_limit: [80, 100])), rails_blob_path(@event_detail.code_of_conduct, disposition: "attachment")) %>
		<% else %>
		    <%= link_to "File", rails_blob_path(@event_detail.code_of_conduct, disposition: "attachment") %>
		<% end %>
    	<%= f.input :policy_code_checked, label: "Checked?" %>
		<br/>
		<br/>
	<% end %>
	
